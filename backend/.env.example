# Database — get from Supabase
DATABASE_URL=postgresql+asyncpg://postgres:password@host:6543/postgres

# JWT — generate a random secret
JWT_SECRET=change-me-to-a-random-string

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# MJ Proxy (domestic)
# MJ_API_URL=https://your-mj-proxy.com
# MJ_API_KEY=your-mj-key

# Brevo SMTP
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USERNAME=your-brevo-username
# SMTP_PASSWORD=your-brevo-password
# EMAIL_FROM=hello@postmate.net
# EMAIL_FROM_NAME=PostMate Team

# CORS
CORS_ORIGINS=http://localhost:8000,https://postmate.net
